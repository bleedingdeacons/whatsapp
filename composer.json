{
    "name": "bleeding-deacons/whatsapp",
    "description": "Rabbit driver for the WhatsApp Business Cloud API (Meta Graph API). Sends messages to Unity members via /<phone-number-id>/messages.",
    "type": "wordpress-plugin",
    "license": "MIT (Modified)",
    "authors": [
        {
            "name": "The Bleeding Deacons"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0",
        "10up/wp_mock": "^0.4.2",
        "mockery/mockery": "^1.4",
        "squizlabs/php_codesniffer": "^3.6",
        "phpstan/phpstan": "^1.4",
        "szepeviktor/phpstan-wordpress": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Whatsapp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Whatsapp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": "php build.php build:production",
        "build:production": "php build.php build:production",
        "build:dev": "php build.php build:dev",
        "build:clean": "php build.php clean",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "test:coverage": "phpunit --coverage-html ./tests/coverage",
        "cs": "phpcs --standard=WordPress ./src",
        "cs:fix": "phpcbf --standard=WordPress ./src",
        "stan": "phpstan analyse -l 5 ./src",
        "analyse": "phpstan analyse src/",
        "check": [
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
